rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ------------------------------------------------------------------------
    // CORE PRIMITIVES & HELPERS
    // ------------------------------------------------------------------------
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    // The super admin is hardcoded to a specific email
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'omarprroo1@gmail.com';
    }

    function isAdmin() {
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isSupervisor() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'supervisor';
    }

    function isAdminOrSupervisor() {
      return isAdmin() || isSupervisor();
    }

    function isEmployeeOrAdmin() {
      return isSignedIn() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true)
      );
    }

    // ------------------------------------------------------------------------
    // VALIDATION BLUEPRINTS (Anti-Update-Gap)
    // ------------------------------------------------------------------------
    
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt', 'active']) 
        && data.email is string && data.email.size() <= 150
        && (!('name' in data) || (data.name is string && data.name.size() <= 100))
        && data.role in ['admin', 'supervisor', 'employee']
        && data.createdAt is number
        && data.active is bool;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'price'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && (!('unit' in data) || (data.unit is string && data.unit.size() <= 50))
        && data.price is number;
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['id', 'name', 'type', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.type in ['individual', 'shop']
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 50))
        && (!('address' in data) || (data.address is string && data.address.size() <= 300))
        && (!('balance' in data) || data.balance is number)
        && (!('locked' in data) || data.locked is bool)
        && data.createdAt is number;
    }

    function isValidInvoice(data) {
      return data.keys().hasAll(['id', 'customerId', 'date', 'items', 'totalAmount', 'status', 'createdBy'])
        && data.id is string && data.id.size() <= 128
        && data.customerId is string && data.customerId.size() <= 128
        && data.date is number
        && data.items is list && data.items.size() >= 0 && data.items.size() <= 200 // Bound loop/list size
        && data.totalAmount is number
        && (!('paidAmount' in data) || data.paidAmount is number)
        && data.status in ['paid', 'partial', 'unpaid', 'deleted']
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 1024))
        && data.createdBy is string && data.createdBy.size() <= 128
        && (!('deleted' in data) || data.deleted is bool)
        && (!('deletedAt' in data) || data.deletedAt is number)
        && (!('deletedBy' in data) || (data.deletedBy is string && data.deletedBy.size() <= 128));
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['id', 'customerId', 'date', 'amount', 'createdBy'])
        && data.id is string && data.id.size() <= 128
        && data.customerId is string && data.customerId.size() <= 128
        && (!('invoiceId' in data) || (data.invoiceId is string && data.invoiceId.size() <= 128))
        && data.date is number
        && data.amount is number
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 1024))
        && data.createdBy is string && data.createdBy.size() <= 128
        && (!('paymentMethod' in data) || data.paymentMethod in ['cash', 'cheque'])
        && (!('chequeNumber' in data) || (data.chequeNumber is string && data.chequeNumber.size() <= 128))
        && (!('bankName' in data) || (data.bankName is string && data.bankName.size() <= 128))
        && (!('dueDate' in data) || data.dueDate is number)
        && (!('chequeStatus' in data) || data.chequeStatus in ['pending', 'cashed', 'bounced', 'deleted'])
        && (!('deleted' in data) || data.deleted is bool)
        && (!('deletedAt' in data) || data.deletedAt is number)
        && (!('deletedBy' in data) || (data.deletedBy is string && data.deletedBy.size() <= 128));
    }

    // ------------------------------------------------------------------------
    // COLLECTION PATHS & RULES
    // ------------------------------------------------------------------------

    // Users Collection (RBAC & Auth Maps)
    match /users/{userId} {
      allow read: if isEmployeeOrAdmin() || userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().keys().hasAll(['email', 'role', 'createdAt', 'active']) 
        && (
             isAdminOrSupervisor() 
          || (
               userId == request.auth.uid && (
                 (incoming().email == 'omarprroo1@gmail.com' && incoming().role == 'admin') || // Super admin bootstrap
                 (incoming().role == 'employee' && incoming().active == false) // Regular user waits for admin approval
               )
             )
           );

      allow update: if isAdminOrSupervisor() 
        && isValidUser(incoming())
        // Immutable 'createdAt'
        && incoming().createdAt == existing().createdAt
        // Only allow changes to specific fields
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'active']);

      allow delete: if isAdminOrSupervisor() && userId != request.auth.uid; // Cannot delete self
    }

    // Products Catalog
    match /products/{productId} {
      // Both employees and admins can view
      allow read: if isEmployeeOrAdmin();
      
      // Only admins can create/update/delete products
      allow create: if isAdminOrSupervisor() 
        && isValidId(productId)
        && isValidProduct(incoming())
        && incoming().keys().hasAll(['id', 'name', 'price']) 
        && incoming().keys().size() <= 4
        && incoming().id == productId;
        
      allow update: if isAdminOrSupervisor() 
        && isValidProduct(incoming())
        && incoming().id == existing().id
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'unit']);
        
      allow delete: if isAdminOrSupervisor();
    }

    // Customers Directory
    match /customers/{customerId} {
      // Both can read and add customers
      allow read: if isEmployeeOrAdmin();
      
      allow create: if isEmployeeOrAdmin()
        && isValidId(customerId)
        && isValidCustomer(incoming())
        && incoming().keys().hasAll(['id', 'name', 'type', 'createdAt'])
        && incoming().keys().size() <= 9
        && incoming().id == customerId
        // Relax exact equality to allow client-side generated timestamps with network skew
        && incoming().createdAt is number
        && incoming().createdAt <= request.time.toMillis() + 600000;
        
      allow update: if isEmployeeOrAdmin()
        && isValidCustomer(incoming())
        // Robust check for ID and createdAt immutability, allowing them to be written if previously missing
        && (!('id' in existing()) || incoming().id == existing().id)
        && (!('createdAt' in existing()) || incoming().createdAt == existing().createdAt)
        && incoming().diff(existing()).affectedKeys().hasOnly(['id', 'createdAt', 'name', 'type', 'phone', 'address', 'balance', 'locked']);
        
      // Only admins and supervisors can delete a customer
      allow delete: if isAdminOrSupervisor();
    }

    // Invoices
    match /invoices/{invoiceId} {
      allow read: if isEmployeeOrAdmin();
      
      allow create: if isEmployeeOrAdmin()
        && isValidId(invoiceId)
        && isValidInvoice(incoming())
        && incoming().keys().hasAll(['id', 'customerId', 'date', 'items', 'totalAmount', 'status', 'createdBy'])
        && incoming().keys().size() <= 13
        && incoming().id == invoiceId
        && exists(/databases/$(database)/documents/customers/$(incoming().customerId))
        && incoming().createdBy == request.auth.uid
        // Employee can't create an invoice in the past arbitrarily far, or let's just make it simple
        && incoming().date <= request.time.toMillis() + 86400000;
        
      // Admins and supervisors can update anything. Employees can only update status/paidAmount of an unpaid/partial invoice
      allow update: if isEmployeeOrAdmin()
        && isValidInvoice(incoming())
        && incoming().id == existing().id
        && incoming().createdBy == existing().createdBy // Immutable
        && incoming().customerId == existing().customerId // Immutable
        && incoming().date == existing().date // Immutable
        && (
            isAdminOrSupervisor() 
          || 
            (
              incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paidAmount', 'notes', 'deleted', 'deletedAt', 'deletedBy'])
            )
        );
        
      allow delete: if isAdminOrSupervisor();
    }

    // Payments
    match /payments/{paymentId} {
      allow read: if isEmployeeOrAdmin();
      
      allow create: if isEmployeeOrAdmin()
        && isValidId(paymentId)
        && isValidPayment(incoming())
        && incoming().keys().hasAll(['id', 'customerId', 'date', 'amount', 'createdBy'])
        && incoming().keys().size() <= 16
        && incoming().id == paymentId
        && exists(/databases/$(database)/documents/customers/$(incoming().customerId))
        && incoming().createdBy == request.auth.uid;
        
      // Only Admins and Supervisors can modify or delete financial records directly once created
      // Employees can only append new payments
      allow update: if isAdminOrSupervisor()
        && isValidPayment(incoming())
        && (!('id' in existing()) || incoming().id == existing().id)
        && (!('createdBy' in existing()) || incoming().createdBy == existing().createdBy) // Robust/Immutable
        && (!('customerId' in existing()) || incoming().customerId == existing().customerId) // Robust/Immutable
        && incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'date', 'notes', 'invoiceId', 'paymentMethod', 'chequeNumber', 'bankName', 'dueDate', 'chequeStatus', 'deleted', 'deletedAt', 'deletedBy']);
        
      allow delete: if isAdminOrSupervisor();
    }

  }
}
